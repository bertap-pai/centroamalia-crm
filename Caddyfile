# Caddy reverse proxy for intranet.centroamalia.com
# Handles TLS automatically via Let's Encrypt.
# Run alongside docker-compose.prod.yml on the host.
#
# Usage:
#   caddy run --config Caddyfile
#
# Or add a caddy service to docker-compose.prod.yml and mount this file.

intranet.centroamalia.com {
    reverse_proxy localhost:80
}
