# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/crm

# Google OAuth — create at https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Session — generate with: openssl rand -base64 32
SESSION_SECRET=change-me-min-32-chars-xxxxxxxxxxxxxxxx

# Auth allowlist — any @centroamalia.com email is allowed (domain-wide, no individual allowlist needed)
ALLOWED_EMAIL_DOMAIN=centroamalia.com
# ALLOWED_EMAILS=extra@example.com,admin@example.com

# URLs (production)
# API_URL: used to build the OAuth callback URL → must match what you register in Google Cloud Console
#   Callback URL to register in Google Console: https://intranet.centroamalia.com/crm/auth/google/callback
# WEB_URL: where the API redirects the browser after login — must include the /crm sub-path
API_URL=https://intranet.centroamalia.com/crm
WEB_URL=https://intranet.centroamalia.com/crm

# ── Meta Lead Ads webhook ─────────────────────────────────────────────────────
# META_VERIFY_TOKEN: any secret string you choose when registering the webhook in Meta Business
META_VERIFY_TOKEN=change-me-random-verify-token
# META_APP_SECRET: from your Meta App → Settings → Basic → App Secret
META_APP_SECRET=your-meta-app-secret
# META_PAGE_ACCESS_TOKEN: long-lived page access token with leads_retrieval permission
META_PAGE_ACCESS_TOKEN=your-meta-page-access-token
# META_DEFAULT_PIPELINE_ID / META_DEFAULT_STAGE_ID: pipeline+stage where meta leads land
META_DEFAULT_PIPELINE_ID=your-pipeline-uuid
META_DEFAULT_STAGE_ID=your-stage-uuid

# ── TikTok Lead Ads webhook ───────────────────────────────────────────────────
# TIKTOK_WEBHOOK_SECRET: secret for HMAC-SHA256 verification of incoming TikTok webhooks
TIKTOK_WEBHOOK_SECRET=your-tiktok-webhook-secret
# TIKTOK_ACCESS_TOKEN: long-lived access token for the TikTok Business API (leads retrieval)
TIKTOK_ACCESS_TOKEN=your-tiktok-access-token
# TIKTOK_DEFAULT_PIPELINE_ID / TIKTOK_DEFAULT_STAGE_ID: pipeline+stage where TikTok leads land
TIKTOK_DEFAULT_PIPELINE_ID=your-pipeline-uuid
TIKTOK_DEFAULT_STAGE_ID=your-stage-uuid

# ── Postgres (used by docker-compose.prod.yml) ────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=crm
